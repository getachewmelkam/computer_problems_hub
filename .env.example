# Firebase Web App configuration
# Get these values from: Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
# Copy this file to ".env" and fill in your real values. Never commit the real ".env" file.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=computer-hubs.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=computer-hubs
VITE_FIREBASE_STORAGE_BUCKET=computer-hubs.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
